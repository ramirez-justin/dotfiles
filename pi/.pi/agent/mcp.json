{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "lifecycle": "lazy",
      "directTools": true
    },
    "sofia-cloud": {
      "url": "https://avgjtkgppeeihntsyjpy.supabase.co/functions/v1/sofia-core",
      "headers": {
        "x-sofia-key": "${SOFIA_MCP_ACCESS_KEY}"
      },
      "auth": false,
      "lifecycle": "lazy"
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp",
      "auth": "oauth",
      "lifecycle": "lazy"
    }
  }
}
