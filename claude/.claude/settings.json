{
  "env": {
    "JIRA_HOST": "gametime.atlassian.net",
    "JIRA_EMAIL": "justin.ramirez@gametime.co",
    "JIRA_API_TOKEN": "",
    "FIVETRAN_API_KEY": "",
    "FIVETRAN_API_SECRET": "",
    "FIVETRAN_GROUP_ID": "",
    "ENABLE_LSP_TOOL": "1"
  },
  "includeCoAuthoredBy": false,
  "model": "opus",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Submarine.aiff"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mise exec node@20 -- node \"$HOME/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/justin/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "workflow@productivity-plugins": true,
    "bash-ls@productivity-plugins": true,
    "docker-ls@productivity-plugins": true,
    "markdown-oxide@productivity-plugins": true,
    "vim-ls@productivity-plugins": true,
    "yaml-ls@productivity-plugins": true,
    "pyright-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true,
    "jira@productivity-plugins": true,
    "dbt@dbt-agent-marketplace": true,
    "fivetran@productivity-plugins": true,
    "playwright@claude-plugins-official": true,
    "terraform-lsp@terraform-lsp-claude-code": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "medium",
  "autoCompactEnabled": false,
  "theme": "dark-daltonized"
}
